# ── AutoAdvertise Bot — Environment Variables ──────────────────
# Copy this to .env for local dev. On Railway, set these in the
# project's Variables tab.

# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=

# Discord application client ID
DISCORD_CLIENT_ID=

# MongoDB Atlas connection string (same DB as the main API server)
MONGODB_URI=

# Comma-separated Discord user IDs allowed to use bot commands
# Example: 123456789012345678,987654321098765432
ADMIN_DISCORD_IDS=
